<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/purple_light">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_primary"
        android:elevation="4dp"
        app:navigationIcon="@drawable/ic_back"
        app:title="营业额统计"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_range"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    android:text="选择时间段"
                    app:cornerRadius="24dp"
                    app:backgroundTint="@color/purple_primary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="重置"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/purple_primary"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_date_range"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="全部时间汇总"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center"
                android:layout_marginBottom="16dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="今日销售额"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tv_today_revenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¥0.00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/revenue_orange"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="本月销售额"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tv_month_revenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¥0.00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/purple_secondary"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="累计销售总额"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tv_total_revenue"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¥0.00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/revenue_orange"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="进货总成本"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tv_total_cost"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¥0.00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/cost_red"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="累计毛利"
                        android:textSize="14sp"
                        android:textColor="@color/text_secondary"/>

                    <TextView
                        android:id="@+id/tv_total_profit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="¥0.00"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/profit_positive"/>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="按月统计"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <ListView
                    android:id="@+id/list_view_monthly"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:divider="@color/divider"
                    android:dividerHeight="1dp"
                    android:nestedScrollingEnabled="true"
                    android:padding="8dp"/>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
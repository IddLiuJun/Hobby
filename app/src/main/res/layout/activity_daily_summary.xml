<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/purple_light">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/purple_primary"
        android:elevation="4dp"
        app:navigationIcon="@drawable/ic_back"
        app:title="每日汇总录入"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="录入日期"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <DatePicker
                android:id="@+id/date_picker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:calendarViewShown="true"
                android:spinnersShown="false"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="商品信息"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <EditText
                android:id="@+id/edt_product_name"
                android:hint="商品名称 *"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/input_background"
                android:textColorHint="@color/text_hint"/>

            <EditText
                android:id="@+id/edt_product_code"
                android:hint="商品编码 *"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="12dp"
                android:paddingHorizontal="16dp"
                android:background="@drawable/input_background"
                android:textColorHint="@color/text_hint"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/edt_spec"
                    android:hint="规格备注"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/input_background"
                    android:textColorHint="@color/text_hint"/>

                <EditText
                    android:id="@+id/edt_customer"
                    android:hint="客户备注"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:paddingHorizontal="16dp"
                    android:background="@drawable/input_background"
                    android:textColorHint="@color/text_hint"/>

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="出入库数量"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/edt_in_quantity"
                    android:hint="入库数量"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    android:paddingHorizontal="16dp"
                    android:inputType="number"
                    android:background="@drawable/input_background"
                    android:textColorHint="@color/text_hint"/>

                <EditText
                    android:id="@+id/edt_out_quantity"
                    android:hint="出库数量"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:paddingHorizontal="16dp"
                    android:inputType="number"
                    android:background="@drawable/input_background"
                    android:textColorHint="@color/text_hint"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <EditText
                    android:id="@+id/edt_price"
                    android:hint="单价 *"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    android:paddingHorizontal="16dp"
                    android:inputType="numberDecimal"
                    android:background="@drawable/input_background"
                    android:textColorHint="@color/text_hint"/>

                <Spinner
                    android:id="@+id/spinner_category"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/input_background"
                    android:paddingHorizontal="8dp"/>

            </LinearLayout>

            <Spinner
                android:id="@+id/spinner_operation_type"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/input_background"
                android:paddingHorizontal="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginBottom="16dp"
                android:text="+ 添加汇总记录"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:backgroundTint="@color/purple_primary"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="筛选日期范围"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_select_range"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:layout_marginRight="8dp"
                    android:text="选择时间段"
                    app:cornerRadius="24dp"
                    app:backgroundTint="@color/purple_primary"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_show_all"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:text="显示全部"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    app:cornerRadius="24dp"
                    app:strokeColor="@color/purple_primary"/>

            </LinearLayout>

            <TextView
                android:id="@+id/tv_date_range"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="当前显示：全部记录"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="汇总记录列表"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <ListView
                    android:id="@+id/list_view_summaries"
                    android:layout_width="match_parent"
                    android:layout_height="300dp"
                    android:divider="@color/divider"
                    android:dividerHeight="1dp"
                    android:padding="8dp"/>

            </androidx.cardview.widget.CardView>

        </LinearLayout>

    </ScrollView>

</LinearLayout>